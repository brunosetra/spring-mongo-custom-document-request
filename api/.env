# PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/doc_request_db
DB_USERNAME=docrequest
DB_PASSWORD=docrequest

# MongoDB
MONGODB_URI=mongodb://localhost:27017/doc_request_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_PREFIX=docrequest

# Keycloak OAuth2
KEYCLOAK_ISSUER_URI=http://localhost:8080/realms/doc-request
KEYCLOAK_JWK_SET_URI=http://localhost:8080/realms/doc-request/protocol/openid-connect/certs

# Application
APP_TENANT_CLAIM=tenant_id
APP_ROLES_CLAIM=realm_access.roles
APP_FILE_MAX_SIZE_MB=10
APP_VALIDATION_EXTERNAL_TIMEOUT=10
LOG_LEVEL=DEBUG
SERVER_PORT=8081